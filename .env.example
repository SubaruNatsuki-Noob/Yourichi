# ── Required ───────────────────────────────────────────────
TG_BOT_TOKEN=your_bot_token_here
OWNER_ID=your_telegram_user_id
CHANNEL_ID=-100xxxxxxxxxx          # DB/storage channel — bot must be admin here

DATABASE_URL=mongodb+srv://...
DATABASE_NAME=AlisaFileBot

# ── Webhook / Polling ──────────────────────────────────────
# True  = Webhook mode (recommended on Render — faster, no wasted CPU)
# False = Polling mode (good for local dev / testing)
WEBHOOK=True
WEBHOOK_URL=https://your-app-name.onrender.com   # your Render public URL
WEBHOOK_PATH=/webhook                             # internal route Telegram posts to

# ── Web server ─────────────────────────────────────────────
PORT=8080

# ── Optional ───────────────────────────────────────────────
OWNER=your_username                # without @
PROTECT_CONTENT=False              # True = prevent users from forwarding files
DISABLE_CHANNEL_BUTTON=False
FSUB_LINK_EXPIRY=60

START_PIC=https://...              # Photo URL shown on /start  (leave blank to disable)
FORCE_PIC=https://...              # Photo URL shown on force-sub screen

# Caption template — variables: {title} {clean_title} {episode} {season} {quality} {extension}
CUSTOM_CAPTION=<b>• {title}</b>

BAN_SUPPORT=https://t.me/your_support_group
